@startuml

left to right direction

' =======================
' ACTEURS (avec héritage)
' =======================
actor "Visiteur" as V
actor "Bibliothécaire" as B
actor "Administrateur" as A

' Héritage (spécialisation)
B --|> V
A --|> B

' =======================
' CAS D'UTILISATION
' =======================
usecase "S'inscrire" as UC1
usecase "Se connecter" as UC2
usecase "Rechercher un livre" as UC3
usecase "Consulter catalogue" as UC4
usecase "Emprunter un livre" as UC5
usecase "Retourner un livre" as UC6
usecase "Réserver un livre" as UC7
usecase "Consulter historique" as UC8

usecase "Ajouter un livre" as UC9
usecase "Supprimer un livre" as UC10
usecase "Gérer emprunts" as UC11
usecase "Gérer utilisateurs" as UC12
usecase "Générer rapports" as UC13

' =======================
' LIENS ACTEURS - USE CASES
' =======================
V --> UC1
V --> UC2
V --> UC3
V --> UC4
V --> UC7

B --> UC5
B --> UC6
B --> UC8
B --> UC11

A --> UC9
A --> UC10
A --> UC12
A --> UC13

' =======================
' INCLUDE / EXTEND
' =======================
UC5 ..> UC2 : <<include>>
UC6 ..> UC2 : <<include>>
UC7 ..> UC2 : <<include>>

UC3 ..> UC4 : <<include>>

UC5 ..> UC7 : <<extend>>
UC8 ..> UC2 : <<include>>

UC11 ..> UC5 : <<include>>
UC11 ..> UC6 : <<include>>

@enduml